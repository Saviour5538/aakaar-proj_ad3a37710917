# Backend configuration
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database_name> # Connection string for the PostgreSQL database
JWT_SECRET=<random_secret> # Secret key for signing JWT tokens
PORT=8000 # Port for the backend server

# Frontend configuration
VITE_API_URL=http://localhost:8000 # API URL for the frontend to communicate with the backend

# PostgreSQL configuration (used in docker-compose)
POSTGRES_USER=postgres # PostgreSQL username
POSTGRES_PASSWORD=postgres # PostgreSQL password
POSTGRES_DB=taskflow # PostgreSQL database name
POSTGRES_HOST=pgdb # PostgreSQL host (service name in docker-compose)
POSTGRES_PORT=5432 # PostgreSQL port